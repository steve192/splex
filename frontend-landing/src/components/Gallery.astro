---
import { Image } from "astro:assets";
import { getContent, type Lang } from "../content";
import { shot } from "../screenshots";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getContent(lang).gallery;
---

<section id="screenshots" class="border-y border-line bg-bg-soft py-20 sm:py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">{t.heading}</h2>
      <p class="mt-4 text-muted">{t.subheading}</p>
    </div>
  </div>

  <div class="snap-row mt-12 flex gap-5 overflow-x-auto px-4 pb-4 sm:px-6">
    {
      t.items.map((item) => (
        <figure class="snap-item flex-none">
          <div class="rounded-[2rem] border border-line bg-surface-2 p-2 shadow-xl shadow-black/40">
            <Image
              src={shot(item.shot)}
              alt={item.label}
              widths={[240, 360]}
              sizes="240px"
              class="h-auto w-52 rounded-[1.5rem] sm:w-60"
              loading="lazy"
            />
          </div>
          <figcaption class="mt-3 text-center text-sm text-muted">{item.label}</figcaption>
        </figure>
      ))
    }
  </div>
</section>
