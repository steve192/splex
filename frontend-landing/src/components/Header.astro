---
import { links, site } from "../site";
import { getContent, languages, localePath, type Lang } from "../content";
import GithubIcon from "./icons/GithubIcon.astro";

interface Props {
  lang: Lang;
  paths?: Partial<Record<Lang, string>>;
}
const { lang, paths } = Astro.props;
const t = getContent(lang).header;
const locales = Object.keys(languages) as Lang[];
const homePath = localePath(lang);
---

<header class="sticky top-0 z-50 border-b border-line/70 bg-bg/80 backdrop-blur">
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6">
    <a href={homePath} class="flex items-center gap-2.5 font-bold tracking-tight">
      <img src="/favicon.png" alt="" width="32" height="32" class="h-8 w-8 rounded-lg" />
      <span class="text-lg">{site.name}</span>
    </a>

    <div class="flex items-center gap-1 sm:gap-2">
      <a
        href={`${homePath}#features`}
        class="hidden rounded-lg px-3 py-2 text-sm text-muted transition hover:text-text sm:block"
        >{t.features}</a
      >
      <a
        href={`${homePath}#guides`}
        class="hidden rounded-lg px-3 py-2 text-sm text-muted transition hover:text-text sm:block"
        >{t.guides}</a
      >
      <a
        href={`${homePath}#documentation`}
        class="hidden rounded-lg px-3 py-2 text-sm text-muted transition hover:text-text sm:block"
        >{t.documentation}</a
      >
      <a
        href={`${homePath}#self-host`}
        class="hidden rounded-lg px-3 py-2 text-sm text-muted transition hover:text-text sm:block"
        >{t.selfhost}</a
      >

      <div class="mx-1 flex items-center gap-0.5 rounded-lg border border-line p-0.5 text-xs font-semibold">
        {
          locales.map((code) => (
            <a
              href={paths?.[code] ?? localePath(code)}
              data-set-lang={code}
              hreflang={code}
              aria-current={code === lang ? "true" : undefined}
              class:list={[
                "rounded-md px-2 py-1 uppercase transition",
                code === lang ? "bg-surface text-text" : "text-muted hover:text-text"
              ]}
            >
              {code}
            </a>
          ))
        }
      </div>

      <a
        href={links.github}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={t.githubAria}
        class="grid h-9 w-9 place-items-center rounded-lg text-muted transition hover:bg-surface hover:text-text"
      >
        <GithubIcon class="h-5 w-5" />
      </a>
      <a
        href={links.login}
        class="rounded-lg border border-line px-3.5 py-2 text-sm font-medium text-text transition hover:border-brand hover:text-brand"
        >{t.login}</a
      >
    </div>
  </nav>
</header>
