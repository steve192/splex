---
import Layout from "../layouts/Layout.astro";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import { getContent, localePath, type Lang } from "../content";
import { glossaryPagePaths, localizedGlossaryPage } from "../glossaryPages";
import { site } from "../site";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const current = localizedGlossaryPage(lang);
const paths = glossaryPagePaths();
const homePath = localePath(lang);
const t = getContent(lang);
const synonymsLabel = lang === "de" ? "Auch genannt" : "Also called";

const canonical = new URL(current.path, Astro.site).toString();
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: site.name,
      item: new URL(homePath, Astro.site).toString()
    },
    {
      "@type": "ListItem",
      position: 2,
      name: current.title,
      item: canonical
    }
  ]
};
---

<Layout
  lang={lang}
  title={current.title}
  description={current.description}
  paths={paths}
  jsonLd={breadcrumbJsonLd}
>
  <Header lang={lang} paths={paths} />
  <main id="top">
    <section class="border-b border-line bg-bg-soft">
      <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6 sm:py-20">
        <a href={homePath} class="text-sm font-semibold text-brand transition hover:text-text">
          {lang === "de" ? "Zur Startseite" : "Back to home"}
        </a>
        <p class="mt-8 text-sm font-semibold uppercase tracking-wider text-brand">{current.eyebrow}</p>
        <h1 class="mt-3 text-4xl font-extrabold tracking-tight sm:text-5xl">{current.h1}</h1>
        <div class="mt-6 space-y-4 text-lg leading-8 text-muted">
          {current.lead.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-5xl px-4 py-14 sm:px-6 sm:py-20">
      <div class="grid gap-4 sm:grid-cols-2">
        {
          current.terms.map((entry) => (
            <article class="rounded-xl border border-line bg-surface p-5">
              <h2 class="text-xl font-bold tracking-tight">{entry.term}</h2>
              <p class="mt-3 text-xs font-semibold uppercase tracking-wider text-brand">{synonymsLabel}</p>
              <div class="mt-3 flex flex-wrap gap-2">
                {entry.synonyms.map((synonym) => (
                  <span class="rounded-full border border-line bg-bg-soft px-2.5 py-1 text-xs text-muted">
                    {synonym}
                  </span>
                ))}
              </div>
              <p class="mt-4 text-sm leading-6 text-muted">{entry.description}</p>
              {
                entry.link && (
                  <a href={entry.link.href} class="mt-4 inline-flex text-sm font-semibold text-brand transition hover:text-text">
                    {entry.link.label}
                  </a>
                )
              }
            </article>
          ))
        }
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 pb-24 sm:px-6">
      <div class="brand-glow relative overflow-hidden rounded-3xl border border-line bg-surface px-6 py-12 text-center sm:px-12">
        <h2 class="mx-auto max-w-2xl text-2xl font-bold tracking-tight sm:text-3xl">
          {lang === "de" ? "Mehr Details stehen in der Dokumentation" : "More detail is in the documentation"}
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-muted">
          {
            lang === "de"
              ? "Das Glossar ist kurz gehalten. Die verlinkten Dokumentationsseiten erklären die Regeln dahinter genauer."
              : "The glossary stays short. The linked documentation pages explain the rules behind the terms in more detail."
          }
        </p>
        <a
          href={`${homePath}#documentation`}
          class="mt-6 inline-flex items-center justify-center rounded-xl bg-brand-strong px-5 py-3 text-sm font-semibold text-bg transition hover:bg-brand"
        >
          {t.footer.links.documentation}
        </a>
      </div>
    </section>
  </main>
  <Footer lang={lang} />
</Layout>
