---
import { links } from "../site";
import { getContent, type Lang } from "../content";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getContent(lang).cta;
---

<section class="mx-auto max-w-6xl px-4 pb-24 sm:px-6">
  <div
    class="brand-glow relative overflow-hidden rounded-3xl border border-line bg-surface px-6 py-14 text-center sm:px-12"
  >
    <h2 class="mx-auto max-w-2xl text-3xl font-bold tracking-tight sm:text-4xl">
      {t.heading}
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-muted">
      {t.paragraph}
    </p>
    <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a
        href={links.app}
        class="inline-flex w-full items-center justify-center rounded-xl bg-brand-strong px-6 py-3 text-base font-semibold text-bg transition hover:bg-brand sm:w-auto"
      >
        {t.ctaApp}
      </a>
      <a
        href={links.playStore}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex w-full items-center justify-center rounded-xl border border-line bg-bg px-6 py-3 text-base font-semibold text-text transition hover:border-brand sm:w-auto"
      >
        {t.ctaPlay}
      </a>
    </div>
  </div>
</section>
