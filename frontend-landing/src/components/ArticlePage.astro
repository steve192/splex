---
import Layout from "../layouts/Layout.astro";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import CTA from "./CTA.astro";
import { links, site } from "../site";
import { getContent, localePath, type Lang } from "../content";
import type { LocalizedContentPage } from "../contentPageTypes";

type RelatedPage = Pick<LocalizedContentPage, "path" | "title" | "description" | "eyebrow">;

interface Props {
  lang: Lang;
  current: LocalizedContentPage;
  paths: Record<Lang, string>;
  related?: RelatedPage[];
  showCta?: boolean;
}

const { lang, current, paths, related = [], showCta = true } = Astro.props;
const t = getContent(lang);
const homePath = localePath(lang);
const copyLabel = lang === "de" ? "Kopieren" : "Copy";
const copiedLabel = lang === "de" ? "Kopiert" : "Copied";
const onThisPageLabel = lang === "de" ? "Auf dieser Seite" : "On this page";
const sectionLabel = lang === "de" ? "Abschnitt" : "Section";

function slugify(value: string): string {
  const slug = value
    .toLowerCase()
    .normalize("NFKD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/&/g, " and ")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

  return slug || "section";
}

const sections = current.sections.map((section, index) => ({
  ...section,
  id: `${slugify(section.heading)}-${index + 1}`,
  number: String(index + 1).padStart(2, "0")
}));

const canonical = new URL(current.path, Astro.site).toString();
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: site.name,
      item: new URL(homePath, Astro.site).toString()
    },
    {
      "@type": "ListItem",
      position: 2,
      name: current.title,
      item: canonical
    }
  ]
};
const faqJsonLd = current.faq
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: current.faq.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.answer
        }
      }))
    }
  : undefined;
const jsonLd = faqJsonLd ? [breadcrumbJsonLd, faqJsonLd] : breadcrumbJsonLd;
---

<Layout
  lang={lang}
  title={current.title}
  description={current.description}
  paths={paths}
  jsonLd={jsonLd}
>
  <Header lang={lang} paths={paths} />
  <main id="top">
    <section class="border-b border-line bg-bg-soft">
      <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-20">
        <a href={homePath} class="text-sm font-semibold text-brand transition hover:text-text">
          {lang === "de" ? "Zur Startseite" : "Back to home"}
        </a>
        <div class="mt-8">
          <div>
            <p class="text-sm font-semibold uppercase tracking-wider text-brand">{current.eyebrow}</p>
            <h1 class="mt-3 max-w-3xl text-4xl font-extrabold tracking-tight sm:text-5xl">{current.h1}</h1>
            <div class="mt-6 max-w-3xl space-y-4 text-lg leading-8 text-muted">
              {current.lead.map((paragraph) => <p>{paragraph}</p>)}
            </div>
          </div>
        </div>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href={links.app}
            class="inline-flex items-center justify-center rounded-xl bg-brand-strong px-5 py-3 text-sm font-semibold text-bg transition hover:bg-brand"
          >
            {t.cta.ctaApp}
          </a>
          <a
            href={links.github}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center rounded-xl border border-line bg-surface px-5 py-3 text-sm font-semibold transition hover:border-brand"
          >
            {lang === "de" ? "Code auf GitHub ansehen" : "Read the code on GitHub"}
          </a>
        </div>
      </div>
    </section>

    <article class="mx-auto grid max-w-6xl gap-10 px-4 py-14 sm:px-6 sm:py-20 lg:grid-cols-[14rem_minmax(0,1fr)]">
      <aside class="hidden lg:block">
        <nav aria-label={onThisPageLabel} data-article-toc class="sticky top-24 border-l border-line pl-4">
          <p class="text-xs font-semibold uppercase tracking-wider text-brand">{onThisPageLabel}</p>
          <ol class="mt-4 space-y-1">
            {
              sections.map((section) => (
                <li>
                  <a
                    href={`#${section.id}`}
                    class="article-toc-link group grid grid-cols-[2rem_minmax(0,1fr)] gap-2 rounded-lg px-2 py-2 text-sm transition hover:bg-surface"
                    data-article-toc-link
                  >
                    <span class="article-toc-number font-mono text-xs leading-6 text-muted group-hover:text-brand">{section.number}</span>
                    <span class="article-toc-label leading-6 text-muted group-hover:text-text">{section.heading}</span>
                  </a>
                </li>
              ))
            }
          </ol>
        </nav>
      </aside>

      <div class="min-w-0 space-y-16">
        {
          sections.map((section) => (
            <section id={section.id} data-article-section class="scroll-mt-28 border-b border-line pb-12 last:border-b-0">
              <div class="flex gap-4 sm:gap-5">
                <div
                  class="mt-1 hidden h-10 w-10 flex-none place-items-center rounded-full border border-line bg-surface font-mono text-xs font-semibold text-brand sm:grid"
                  aria-label={`${sectionLabel} ${section.number}`}
                >
                  {section.number}
                </div>
                <div class="min-w-0 flex-1">
                  <p class="font-mono text-xs font-semibold text-brand sm:hidden">{section.number}</p>
                  <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">{section.heading}</h2>
                  <div class="mt-5 space-y-4 text-base leading-7 text-muted">
                {section.blocks.map((block) => {
                  if (block.type === "paragraph") return <p>{block.text}</p>;
                  if (block.type === "code")
                    return (
                      <div class="relative" data-code-block>
                        <button
                          type="button"
                          class="absolute right-3 top-3 rounded-lg border border-line bg-surface px-3 py-1.5 text-xs font-semibold text-text transition hover:border-brand"
                          data-copy-code
                          data-label={copyLabel}
                          data-done-label={copiedLabel}
                        >
                          {copyLabel}
                        </button>
                        <pre class="overflow-x-auto rounded-xl border border-line bg-surface-2 p-4 pr-24 text-sm leading-6 text-text shadow-xl shadow-black/20"><code>{block.code}</code></pre>
                      </div>
                    );
                  if (block.type === "link")
                    return (
                      <div class="rounded-xl border border-brand/30 bg-brand/5 p-4">
                        <p>
                          {block.text ? `${block.text} ` : ""}
                          <a
                            href={block.href}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="font-semibold text-brand transition hover:text-text"
                          >
                            {block.label}
                          </a>
                        </p>
                      </div>
                    );
                  return (
                    <ul class="grid gap-3">
                      {block.items.map((item) => (
                        <li class="grid grid-cols-[1.25rem_minmax(0,1fr)] gap-3 rounded-xl border border-line bg-surface/70 p-4">
                          <span class="mt-2 h-2 w-2 rounded-full bg-brand" aria-hidden="true" />
                          <span class="leading-7">{item}</span>
                        </li>
                      ))}
                    </ul>
                  );
                })}
                  </div>
                </div>
              </div>
            </section>
          ))
        }

        {
          current.table && (
            <section class="rounded-xl border border-line bg-surface/50 p-4 sm:p-5">
              <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
                {lang === "de" ? "Im direkten Vergleich" : "Side-by-side comparison"}
              </h2>
              <div class="mt-5 overflow-hidden rounded-xl border border-line">
                <table class="w-full border-collapse text-left text-sm">
                  <thead class="bg-surface-2 text-text">
                    <tr>
                      {current.table.columns.map((column) => (
                        <th class="border-b border-line px-4 py-3 font-semibold">{column}</th>
                      ))}
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-line">
                    {current.table.rows.map((row) => (
                      <tr class="align-top transition hover:bg-surface/80">
                        {row.map((cell, index) => (
                          <td class:list={["px-4 py-4 text-muted", index === 0 && "font-semibold text-text"]}>
                            {cell}
                          </td>
                        ))}
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </section>
          )
        }

        {
          current.faq && (
            <section>
              <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
                {lang === "de" ? "Häufige Fragen" : "Common questions"}
              </h2>
              <div class="mt-5 divide-y divide-line rounded-xl border border-line bg-surface">
                {current.faq.map((item) => (
                  <details class="group p-5">
                    <summary class="flex cursor-pointer list-none items-start justify-between gap-4 font-semibold text-text">
                      <span>{item.question}</span>
                      <span class="mt-0.5 text-brand transition group-open:rotate-45" aria-hidden="true">+</span>
                    </summary>
                    <p class="mt-3 leading-7 text-muted">{item.answer}</p>
                  </details>
                ))}
              </div>
            </section>
          )
        }

        {
          related.length > 0 && (
            <section class="rounded-2xl border border-line bg-surface p-6">
              <h2 class="text-xl font-bold tracking-tight">
                {lang === "de" ? "Weiterlesen" : "Read next"}
              </h2>
              <div class="mt-5 grid gap-4 sm:grid-cols-2">
                {related.map((relatedPage) => (
                  <a
                    href={relatedPage.path}
                    class="rounded-xl border border-line bg-bg-soft p-4 transition hover:border-brand"
                  >
                    <p class="text-sm font-semibold text-brand">{relatedPage.eyebrow}</p>
                    <h3 class="mt-2 font-semibold text-text">{relatedPage.title}</h3>
                    <p class="mt-2 text-sm leading-6 text-muted">{relatedPage.description}</p>
                  </a>
                ))}
              </div>
            </section>
          )
        }
      </div>
    </article>
    {showCta && <CTA lang={lang} />}
  </main>
  <Footer lang={lang} />
</Layout>

<style>
  .article-toc-link[aria-current="true"] {
    background: color-mix(in srgb, var(--color-surface) 88%, var(--color-brand));
  }

  .article-toc-link[aria-current="true"] .article-toc-number {
    color: var(--color-brand);
  }

  .article-toc-link[aria-current="true"] .article-toc-label {
    color: var(--color-text);
  }
</style>

<script>
  async function copyText(text: string): Promise<boolean> {
    if (!navigator.clipboard?.writeText) return false;
    await navigator.clipboard.writeText(text);
    return true;
  }

  document.querySelectorAll<HTMLButtonElement>("[data-copy-code]").forEach((button) => {
    button.addEventListener("click", async () => {
      const code = button.closest("[data-code-block]")?.querySelector("code")?.textContent;
      if (!code) return;

      const copied = await copyText(code);
      if (!copied) return;

      const label = button.getAttribute("data-label") ?? button.textContent ?? "Copy";
      button.textContent = button.getAttribute("data-done-label") ?? "Copied";
      window.setTimeout(() => {
        button.textContent = label;
      }, 1600);
    });
  });

  function setupArticleToc(): void {
    const sections = Array.from(document.querySelectorAll<HTMLElement>("[data-article-section]"));
    const links = new Map<string, HTMLAnchorElement>();
    document.querySelectorAll<HTMLAnchorElement>("[data-article-toc-link]").forEach((link) => {
      const sectionId = link.hash.slice(1);
      if (sectionId) links.set(sectionId, link);
    });
    if (sections.length === 0 || links.size === 0) return;

    function setActive(sectionId: string): void {
      links.forEach((link, id) => {
        if (id === sectionId) {
          link.setAttribute("aria-current", "true");
          return;
        }
        link.removeAttribute("aria-current");
      });
    }

    function updateActiveSection(): void {
      const marker = window.innerHeight * 0.28;
      let activeSection = sections[0];

      for (const section of sections) {
        if (section.getBoundingClientRect().top <= marker) {
          activeSection = section;
        }
      }

      setActive(activeSection.id);
    }

    let animationFrame = 0;
    function scheduleUpdate(): void {
      window.cancelAnimationFrame(animationFrame);
      animationFrame = window.requestAnimationFrame(updateActiveSection);
    }

    updateActiveSection();
    window.addEventListener("scroll", scheduleUpdate, { passive: true });
    window.addEventListener("resize", scheduleUpdate);
  }

  setupArticleToc();
</script>
