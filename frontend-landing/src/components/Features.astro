---
import { Image } from "astro:assets";
import { getContent, type Lang } from "../content";
import { shot } from "../screenshots";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getContent(lang).features;
---

<section id="features" class="mx-auto max-w-6xl px-4 py-20 sm:px-6 sm:py-28">
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">{t.heading}</h2>
    <p class="mt-4 text-muted">{t.subheading}</p>
  </div>

  <div class="mt-16 flex flex-col gap-20 sm:gap-28">
    {
      t.items.map((feature, index) => (
        <div class="grid items-center gap-10 sm:grid-cols-2 sm:gap-14">
          <div class={index % 2 === 1 ? "sm:order-2" : ""}>
            <p class="text-sm font-semibold uppercase tracking-wider text-brand">{feature.eyebrow}</p>
            <h3 class="mt-2 text-2xl font-bold tracking-tight sm:text-3xl">{feature.title}</h3>
            <p class="mt-3 text-muted">{feature.body}</p>
            <ul class="mt-6 space-y-3">
              {feature.points.map((point) => (
                <li class="flex items-start gap-3">
                  <svg
                    viewBox="0 0 20 20"
                    class="mt-0.5 h-5 w-5 flex-none text-brand"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 9.7a1 1 0 1 1 1.4-1.4l3.3 3.3 6.8-6.8a1 1 0 0 1 1.4 0Z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  <span class="text-sm text-text/90">{point}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class={index % 2 === 1 ? "sm:order-1" : ""}>
            <div class="mx-auto w-fit rounded-[2rem] border border-line bg-surface-2 p-2 shadow-xl shadow-black/40">
              <Image
                src={shot(feature.shot)}
                alt={feature.title}
                widths={[240, 360]}
                sizes="(max-width: 640px) 60vw, 320px"
                class="h-auto w-56 rounded-[1.5rem] sm:w-64"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>
