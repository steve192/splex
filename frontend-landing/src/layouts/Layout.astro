---
// Self-hosted Inter (variable, weight axis only). Bundled into the build so the
// page never contacts Google's font servers. Browsers fetch only the subset
// their content needs (latin covers EN + DE) via unicode-range.
import "@fontsource-variable/inter/wght.css";
import "../styles/global.css";
import { site } from "../site";
import { getContent, type Lang } from "../content";

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
  paths?: Partial<Record<Lang, string>>;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Set true on pages that must stay out of search indexes. */
  noindex?: boolean;
}

const { lang, title, description: pageDescription, paths, jsonLd: extraJsonLd, noindex = false } = Astro.props;
const t = getContent(lang);

const pageTitle = title ? `${title} | ${site.name}` : `${site.name} - ${t.meta.title}`;
const description = pageDescription ?? t.meta.description;

// English lives at "/", German at "/de/". Content pages pass their paired
// locale paths so canonical + hreflang alternates stay tied to the same topic.
const enPath = paths?.en ?? "/";
const dePath = paths?.de ?? "/de/";
const enUrl = new URL(enPath, Astro.site).toString();
const deUrl = new URL(dePath, Astro.site).toString();
const canonical = new URL(lang === "de" ? dePath : enPath, Astro.site).toString();
const ogImage = new URL(site.ogImage, Astro.site).toString();
const ogLocale = lang === "de" ? "de_DE" : "en_US";
const ogLocaleAlt = lang === "de" ? "en_US" : "de_DE";

const softwareJsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: site.name,
  applicationCategory: "FinanceApplication",
  operatingSystem: "Web, Android",
  inLanguage: lang,
  description,
  url: canonical
};
const jsonLd = extraJsonLd
  ? [softwareJsonLd, ...(Array.isArray(extraJsonLd) ? extraJsonLd : [extraJsonLd])]
  : softwareJsonLd;
const languageRedirectScript = `
      (function () {
        try {
          var enPath = ${JSON.stringify(enPath)};
          var dePath = ${JSON.stringify(dePath)};
          var path = location.pathname;
          var current =
            path === "/de" || path === "/de/" || path.indexOf("/de/") === 0 ? "de" : "en";
          var stored = localStorage.getItem("splex-lang");
          if (stored === "en" || stored === "de") {
            if (stored !== current) location.replace(stored === "de" ? dePath : enPath);
            return;
          }
          if (current === "en") {
            var langs = (navigator.languages || [navigator.language || ""]).join(",");
            if (/(^|,)\\s*de/i.test(langs)) location.replace(dePath);
          }
        } catch (e) {}
      })();
    `;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Redirect first-time visitors to their preferred language (and honor a
         stored manual choice). Runs before paint to avoid a flash. -->
    <script is:inline set:html={languageRedirectScript}></script>

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="de" href={deUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />

    <meta name="theme-color" content="#0c100e" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />

    <!-- Persist the visitor's manual language choice so the redirect above
         respects it on later visits. -->
    <script is:inline>
      document.querySelectorAll("[data-set-lang]").forEach(function (el) {
        el.addEventListener("click", function () {
          try {
            localStorage.setItem("splex-lang", el.getAttribute("data-set-lang"));
          } catch (e) {}
        });
      });
    </script>
  </body>
</html>
