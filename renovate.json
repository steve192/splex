{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits"
  ],
  "timezone": "UTC",
  "dependencyDashboard": true,
  "rangeStrategy": "pin",
  "minimumReleaseAge": "7 days",
  "platformAutomerge": true,
  "automergeType": "branch",
  "labels": [
    "dependencies"
  ],
  "packageRules": [
    {
      "description": "Safely automerge patch and digest updates",
      "matchUpdateTypes": [
        "patch",
        "digest"
      ],
      "automerge": true
    },
    {
      "description": "Never automerge major updates",
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    },
    {
      "description": "Frontend: Expo / React Native ecosystem - grouped, manually reviewed",
      "matchManagers": [
        "npm"
      ],
      "matchFileNames": [
        "frontend/**"
      ],
      "matchPackageNames": [
        "expo",
        "expo-*",
        "@expo/*",
        "react-native",
        "react-native-*"
      ],
      "groupName": "expo-and-react-native"
    },
    {
      "description": "Frontend: other npm minor/patch updates",
      "matchManagers": [
        "npm"
      ],
      "matchFileNames": [
        "frontend/**"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "frontend-dependencies",
      "automerge": true
    },
    {
      "description": "Backend: Python runtime/dev dependencies from pyproject (PEP 621)",
      "matchManagers": [
        "pep621"
      ],
      "matchFileNames": [
        "backend/**"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "python-dependencies",
      "automerge": true
    },
    {
      "description": "Docker base images (runtime)",
      "matchManagers": [
        "dockerfile",
        "docker-compose"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "docker-base-images",
      "automerge": true
    },
    {
      "description": "GitHub Actions workflow dependencies",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "github-actions",
      "automerge": true
    }
  ]
}
