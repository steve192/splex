{
  "name": "splex-frontend",
  "version": "1.0.1",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start --tunnel",
    "android": "expo start --tunnel --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eject": "expo prebuild",
    "build:web": "expo export --platform web --output-dir dist",
    "build-web": "npm run build:web",
    "publish-expo-production": "npx eas update --branch production --auto",
    "publish-expo-preview": "npx eas update --branch preview --auto",
    "publish-preview": "npx eas update --branch preview --auto",
    "build-android": "npx eas build --platform android --profile production",
    "build-android-apk": "npx eas build --platform android --profile production-apk",
    "build-android-dev": "npx eas build --platform android --profile development",
    "build-android-preview": "npx eas build --platform android --profile preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.11",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "3.0.3",
    "@react-native-community/netinfo": "12.0.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.3.16",
    "expo": "~55.0.25",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.16",
    "expo-font": "~55.0.8",
    "expo-image-picker": "~55.0.20",
    "expo-linking": "~55.0.15",
    "expo-notifications": "~55.0.23",
    "expo-router": "~55.0.15",
    "expo-status-bar": "~55.0.6",
    "expo-system-ui": "~55.0.18",
    "expo-updates": "~55.0.23",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-paper": "^5.15.2",
    "react-native-paper-dates": "^0.23.8",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@types/react": "~19.2.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.6",
    "eas-cli": "^18.13.0"
  }
}
