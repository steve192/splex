{
  "name": "splex-frontend",
  "version": "1.3.1",
  "private": true,
  "license": "Splex Non-Commercial Source License 1.0",
  "author": "steve192",
  "homepage": "https://github.com/steve192/splex",
  "repository": {
    "type": "git",
    "url": "https://github.com/steve192/splex.git"
  },
  "main": "index.ts",
  "scripts": {
    "start": "expo start --tunnel",
    "android": "expo start --tunnel --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eject": "expo prebuild",
    "build:web": "expo export --platform web --output-dir dist",
    "build-web": "npm run build:web",
    "publish-expo-production": "npx -p eas-cli eas update --branch production --platform android --auto",
    "publish-expo-preview": "npx -p eas-cli eas update --branch preview --platform android --auto",
    "publish-preview": "npx -p eas-cli eas update --branch preview --platform android --auto",
    "build-android": "npx -p eas-cli eas build --platform android --profile production",
    "build-android-apk": "npx -p eas-cli eas build --platform android --profile production-apk",
    "build-android-dev": "npx -p eas-cli eas build --platform android --profile development",
    "build-android-preview": "npx -p eas-cli eas build --platform android --profile preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:leaflet-assets": "node scripts/build-leaflet-assets.js",
    "build:pwa-icons": "node scripts/build-pwa-icons.js",
    "postinstall": "node scripts/build-leaflet-assets.js && node scripts/build-pwa-icons.js"
  },
  "dependencies": {
    "@expo/metro-runtime": "56.0.13",
    "@expo/vector-icons": "15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-navigation/bottom-tabs": "7.16.2",
    "@react-navigation/native": "7.2.5",
    "@react-navigation/native-stack": "7.16.0",
    "expo": "56.0.8",
    "expo-application": "56.0.3",
    "expo-auth-session": "56.0.13",
    "expo-clipboard": "56.0.3",
    "expo-constants": "56.0.16",
    "expo-crypto": "56.0.4",
    "expo-dev-client": "56.0.18",
    "expo-document-picker": "56.0.4",
    "expo-file-system": "56.0.7",
    "expo-font": "56.0.5",
    "expo-image-manipulator": "~56.0.16",
    "expo-image-picker": "56.0.15",
    "expo-linear-gradient": "56.0.4",
    "expo-linking": "56.0.13",
    "expo-localization": "56.0.6",
    "expo-location": "56.0.15",
    "expo-notifications": "56.0.15",
    "expo-sharing": "56.0.15",
    "expo-splash-screen": "56.0.10",
    "expo-status-bar": "56.0.4",
    "expo-system-ui": "56.0.5",
    "expo-updates": "56.0.17",
    "expo-web-browser": "56.0.5",
    "leaflet": "1.9.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "2.31.2",
    "react-native-gifted-charts": "1.4.77",
    "react-native-paper": "5.15.2",
    "react-native-paper-dates": "0.23.8",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "0.21.2",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@types/leaflet": "1.9.21",
    "@types/react": "19.2.15",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}
