{
  "name": "splex-frontend",
  "version": "1.5.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start --tunnel",
    "android": "expo start --tunnel --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eject": "expo prebuild",
    "build:web": "expo export --platform web --output-dir dist",
    "build-web": "npm run build:web",
    "publish-expo-production": "npx eas update --branch production --platform android --auto",
    "publish-expo-preview": "npx eas update --branch preview --platform android --auto",
    "publish-preview": "npx eas update --branch preview --platform android --auto",
    "build-android": "npx eas build --platform android --profile production",
    "build-android-apk": "npx eas build --platform android --profile production-apk",
    "build-android-dev": "npx eas build --platform android --profile development",
    "build-android-preview": "npx eas build --platform android --profile preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:leaflet-assets": "node scripts/build-leaflet-assets.js",
    "postinstall": "node scripts/build-leaflet-assets.js"
  },
  "dependencies": {
    "@expo/metro-runtime": "56.0.8",
    "@expo/vector-icons": "15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-navigation/bottom-tabs": "7.16.1",
    "@react-navigation/native": "7.2.4",
    "@react-navigation/native-stack": "7.15.1",
    "expo": "55.0.25",
    "expo-auth-session": "56.0.8",
    "expo-clipboard": "56.0.3",
    "expo-constants": "56.0.11",
    "expo-crypto": "56.0.3",
    "expo-font": "56.0.4",
    "expo-image-picker": "56.0.9",
    "expo-linear-gradient": "~56.0.0",
    "expo-linking": "56.0.8",
    "expo-localization": "56.0.4",
    "expo-location": "56.0.9",
    "expo-notifications": "56.0.9",
    "expo-router": "56.2.1",
    "expo-status-bar": "56.0.4",
    "expo-system-ui": "56.0.4",
    "expo-updates": "56.0.12",
    "expo-web-browser": "56.0.4",
    "leaflet": "1.9.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "2.31.2",
    "react-native-gifted-charts": "1.4.77",
    "react-native-paper": "5.15.2",
    "react-native-paper-dates": "0.23.8",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.1",
    "react-native-svg": "15.15.3",
    "react-native-web": "0.21.2",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@types/leaflet": "1.9.21",
    "@types/react": "19.2.15",
    "eas-cli": "18.13.1",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}
