{
  "cli": {
    "version": ">= 0.35.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "distribution": "internal",
        "withoutCredentials": true,
        "buildType": "apk"
      },
      "env": {
        "EX_UPDATES_NATIVE_DEBUG": "1",
        "EXPO_PUBLIC_DEFAULT_API_BASE_URL": "https://splex.sterul.com"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_DEFAULT_API_BASE_URL": "https://splex.sterul.com"
      }
    },
    "production": {
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_DEFAULT_API_BASE_URL": "https://splex.sterul.com"
      }
    },
    "production-apk": {
      "channel": "production",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_DEFAULT_API_BASE_URL": "https://splex.sterul.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
