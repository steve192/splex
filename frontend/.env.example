# Map Configuration (PWA/Web version only)
# The tile URL used for rendering maps in the web/PWA version of the app
# This is only used when viewing expense details in the web application
# The mobile apps (iOS/Android) use their own native map implementations
# Default: https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png (OpenStreetMap)
#
# Customize this if you want to use a different map tile provider
# Examples:
# - Mapbox: https://api.mapbox.com/styles/v1/YOUR_USERNAME/YOUR_STYLE_ID/static/{lng},{lat},{z}/{width}/{height}@2x?access_token=YOUR_TOKEN
# - CartoDB: https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}.png
#
# EXPO_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
